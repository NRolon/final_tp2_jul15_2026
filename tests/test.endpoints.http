DELETE http://localhost:3000/api/v1/habitaciones/8cac7e87-4644-4d9a-93cf-c35d72469f38
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6ImFkbWluIiwiaWF0IjoxNzg0MTU3NDk4LCJleHAiOjE3ODQxNjEwOTh9.vXY6FgNDcmef9-hB3G9smBbUiKlUWROItL06aSAdOLg

### GET - Generar el csv de Pokemones
GET http://localhost:3000/api/v1/pokemon/csv